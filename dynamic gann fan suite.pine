// ============================================================
//  DYNAMIC GANN FAN SUITE  |  Pine Script v5
//  Timeframe: 1H  |  Author: AI Expert Pine Dev
//  Version: 1.0.0
// ============================================================
//@version=5
indicator("Dynamic Gann Fan Suite", overlay=true, max_lines_count=500, max_labels_count=200)

// ─────────────────────────────────────────────────────────────
//  INPUT PARAMETERS
// ─────────────────────────────────────────────────────────────
i_lookback      = input.int(100, "Lookback Period (bars)", minval=10, maxval=500)
i_showBull      = input.bool(true,  "Show Bullish Fan")
i_showBear      = input.bool(true,  "Show Bearish Fan")
i_fanLength     = input.int(200, "Fan Line Length (bars)", minval=50, maxval=1000)
i_showSignals   = input.bool(true,  "Show Buy/Sell Signals")
i_priceFactor   = input.float(1.0, "Price/Bar Ratio Factor", minval=0.01, maxval=100.0, step=0.01,
                  tooltip="Adjust if lines appear too steep/flat. Lock 'Price to Bar Ratio' in chart settings for best results.")

// ─────────────────────────────────────────────────────────────
//  COLORS
// ─────────────────────────────────────────────────────────────
C_BULL_1X1   = color.new(#FFD700, 0)    // Gold  – 45° balance line
C_BULL_OTHER = color.new(#00E5FF, 65)   // Cyan  – other bullish angles
C_BEAR_1X1   = color.new(#FFD700, 0)    // Gold  – -45° balance line
C_BEAR_OTHER = color.new(#FF4C4C, 65)   // Red   – other bearish angles
C_BUY_LBL    = color.new(#00C853, 0)
C_SELL_LBL   = color.new(#FF1744, 0)
C_TP_TXT     = color.new(#FFEB3B, 0)
C_SL_TXT     = color.new(#FF7043, 0)

// ─────────────────────────────────────────────────────────────
//  GANN ANGLE DEFINITIONS
//  Slope = tan(angle_deg * π/180) * priceFactor
//  We work in price-per-bar units.
// ─────────────────────────────────────────────────────────────
// Bullish angles (degrees above horizontal, positive slope)
float[] bullAngles = array.from(18.75, 26.25, 45.0, 63.75, 71.25)
// Bearish angles (degrees below horizontal, negative slope)
float[] bearAngles = array.from(-15.0, -18.75, -26.25, -45.0, -63.25, -71.25, -75.0)

// ─────────────────────────────────────────────────────────────
//  STATE VARIABLES  –  persistent line/label arrays
// ─────────────────────────────────────────────────────────────
var line[]  bullLines  = array.new_line()
var line[]  bearLines  = array.new_line()
var label[] bullLabels = array.new_label()
var label[] bearLabels = array.new_label()
var label[] sigLabels  = array.new_label()

// Track last detected pivot bar indices & prices
var int   lastLowBar   = na
var float lastLowPrice = na
var int   lastHighBar  = na
var float lastHighPrice= na

// ─────────────────────────────────────────────────────────────
//  HELPER: Delete all objects in an array
// ─────────────────────────────────────────────────────────────
cleanLines(line[] arr) =>
    for ln in arr
        line.delete(ln)
    array.clear(arr)

cleanLabels(label[] arr) =>
    for lb in arr
        label.delete(lb)
    array.clear(lb)

// Pine Script doesn't allow calling user functions that modify
// arrays of lines/labels in a loop inside another function easily,
// so we use inline deletion below.

// ─────────────────────────────────────────────────────────────
//  HELPER: Compute price-per-bar slope from angle
// ─────────────────────────────────────────────────────────────
getSlope(float angleDeg) =>
    math.tan(angleDeg * math.pi / 180.0) * i_priceFactor

// ─────────────────────────────────────────────────────────────
//  HELPER: Price of a Gann line at a given bar offset
// ─────────────────────────────────────────────────────────────
gannPrice(float originPrice, float slope, int barsFromOrigin) =>
    originPrice + slope * barsFromOrigin

// ─────────────────────────────────────────────────────────────
//  SWING DETECTION  (Simple: lowest/highest in lookback)
// ─────────────────────────────────────────────────────────────
lowestIdx  = ta.lowestbars(low,  i_lookback)   // bars ago of the low
highestIdx = ta.highestbars(high, i_lookback)   // bars ago of the high

curLowBar   = bar_index - lowestIdx
curLowPrice = low[lowestIdx]
curHighBar  = bar_index - highestIdx
curHighPrice= high[highestIdx]

// ─────────────────────────────────────────────────────────────
//  DETECT NEW PIVOTS  (canvas reset trigger)
// ─────────────────────────────────────────────────────────────
newLow  = na(lastLowBar)  or curLowBar  != lastLowBar
newHigh = na(lastHighBar) or curHighBar != lastHighBar

// ─────────────────────────────────────────────────────────────
//  DRAW BULLISH FAN  (from swing Low)
// ─────────────────────────────────────────────────────────────
if i_showBull and newLow
    // --- Clean old bullish lines & labels ---
    for ln in bullLines
        line.delete(ln)
    array.clear(bullLines)
    for lb in bullLabels
        label.delete(lb)
    array.clear(bullLabels)

    lastLowBar   := curLowBar
    lastLowPrice := curLowPrice

    // Draw each bullish angle
    for i = 0 to array.size(bullAngles) - 1
        ang   = array.get(bullAngles, i)
        slope = getSlope(ang)
        is1x1 = ang == 45.0

        x1 = curLowBar
        y1 = curLowPrice
        x2 = curLowBar + i_fanLength
        y2 = gannPrice(curLowPrice, slope, i_fanLength)

        ln = line.new(
             x1     = x1,
             y1     = y1,
             x2     = x2,
             y2     = y2,
             xloc   = xloc.bar_index,
             extend = extend.right,
             color  = is1x1 ? C_BULL_1X1 : C_BULL_OTHER,
             style  = line.style_solid,
             width  = is1x1 ? 2 : 1)
        array.push(bullLines, ln)

        // Angle label at origin + small offset
        lb = label.new(
             x      = curLowBar + 5,
             y      = gannPrice(curLowPrice, slope, 5),
             text   = str.tostring(ang) + "°",
             xloc   = xloc.bar_index,
             color  = color.new(color.black, 100),
             textcolor = is1x1 ? C_BULL_1X1 : C_BULL_OTHER,
             style  = label.style_none,
             size   = size.tiny)
        array.push(bullLabels, lb)

// ─────────────────────────────────────────────────────────────
//  DRAW BEARISH FAN  (from swing High)
// ─────────────────────────────────────────────────────────────
if i_showBear and newHigh
    // --- Clean old bearish lines & labels ---
    for ln in bearLines
        line.delete(ln)
    array.clear(bearLines)
    for lb in bearLabels
        label.delete(lb)
    array.clear(bearLabels)

    lastHighBar   := curHighBar
    lastHighPrice := curHighPrice

    // Draw each bearish angle
    for i = 0 to array.size(bearAngles) - 1
        ang   = array.get(bearAngles, i)
        slope = getSlope(ang)
        is1x1 = ang == -45.0

        x1 = curHighBar
        y1 = curHighPrice
        x2 = curHighBar + i_fanLength
        y2 = gannPrice(curHighPrice, slope, i_fanLength)

        ln = line.new(
             x1     = x1,
             y1     = y1,
             x2     = x2,
             y2     = y2,
             xloc   = xloc.bar_index,
             extend = extend.right,
             color  = is1x1 ? C_BEAR_1X1 : C_BEAR_OTHER,
             style  = line.style_solid,
             width  = is1x1 ? 2 : 1)
        array.push(bearLines, ln)

        // Angle label
        lb = label.new(
             x      = curHighBar + 5,
             y      = gannPrice(curHighPrice, slope, 5),
             text   = str.tostring(ang) + "°",
             xloc   = xloc.bar_index,
             color  = color.new(color.black, 100),
             textcolor = is1x1 ? C_BEAR_1X1 : C_BEAR_OTHER,
             style  = label.style_none,
             size   = size.tiny)
        array.push(bearLabels, lb)

// ─────────────────────────────────────────────────────────────
//  SIGNAL GENERATION  –  Price crossing Gann lines
// ─────────────────────────────────────────────────────────────
if i_showSignals and not na(lastLowBar) and not na(lastHighBar)

    barsFromLow  = bar_index - lastLowBar
    barsFromHigh = bar_index - lastHighBar

    // ── BUY signals: close crosses UP any bullish Gann level ──
    for i = 0 to array.size(bullAngles) - 1
        ang       = array.get(bullAngles, i)
        slope     = getSlope(ang)
        gannLevel = gannPrice(lastLowPrice, slope, barsFromLow)
        prevLevel = gannPrice(lastLowPrice, slope, barsFromLow - 1)

        crossedUp = close[1] < prevLevel and close >= gannLevel

        if crossedUp
            // TP = next angle level (i+1), SL = previous angle level (i-1) or origin
            tpAng    = i < array.size(bullAngles) - 1 ? array.get(bullAngles, i + 1) : ang * 1.1
            slAng    = i > 0 ? array.get(bullAngles, i - 1) : 0.0
            tpLevel  = gannPrice(lastLowPrice, getSlope(tpAng), barsFromLow)
            slLevel  = i > 0 ? gannPrice(lastLowPrice, getSlope(slAng), barsFromLow) : lastLowPrice

            buyText  = "▲ BUY\n" +
                       "Entry: " + str.tostring(close, "#.####") + "\n" +
                       "TP: "    + str.tostring(tpLevel, "#.####") + "\n" +
                       "SL: "    + str.tostring(slLevel, "#.####")

            lbl = label.new(
                 x         = bar_index,
                 y         = low,
                 text      = buyText,
                 xloc      = xloc.bar_index,
                 yloc      = yloc.belowbar,
                 color     = C_BUY_LBL,
                 textcolor = color.white,
                 style     = label.style_label_up,
                 size      = size.small)
            array.push(sigLabels, lbl)

    // ── SELL signals: close crosses DOWN any bearish Gann level ──
    for i = 0 to array.size(bearAngles) - 1
        ang       = array.get(bearAngles, i)
        slope     = getSlope(ang)
        gannLevel = gannPrice(lastHighPrice, slope, barsFromHigh)
        prevLevel = gannPrice(lastHighPrice, slope, barsFromHigh - 1)

        crossedDown = close[1] > prevLevel and close <= gannLevel

        if crossedDown
            // TP = next lower angle (i+1 is more negative), SL = previous angle (i-1) or origin
            tpAng   = i < array.size(bearAngles) - 1 ? array.get(bearAngles, i + 1) : ang * 1.1
            slAng   = i > 0 ? array.get(bearAngles, i - 1) : 0.0
            tpLevel = gannPrice(lastHighPrice, getSlope(tpAng), barsFromHigh)
            slLevel = i > 0 ? gannPrice(lastHighPrice, getSlope(slAng), barsFromHigh) : lastHighPrice

            sellText = "▼ SELL\n" +
                       "Entry: " + str.tostring(close, "#.####") + "\n" +
                       "TP: "    + str.tostring(tpLevel, "#.####") + "\n" +
                       "SL: "    + str.tostring(slLevel, "#.####")

            lbl = label.new(
                 x         = bar_index,
                 y         = high,
                 text      = sellText,
                 xloc      = xloc.bar_index,
                 yloc      = yloc.abovebar,
                 color     = C_SELL_LBL,
                 textcolor = color.white,
                 style     = label.style_label_down,
                 size      = size.small)
            array.push(sigLabels, lbl)

// ─────────────────────────────────────────────────────────────
//  SIGNAL LABEL CLEANUP  –  keep last 50 signal labels only
// ─────────────────────────────────────────────────────────────
if array.size(sigLabels) > 50
    label.delete(array.shift(sigLabels))

// ─────────────────────────────────────────────────────────────
//  ORIGIN MARKERS  –  dots at fan pivot points
// ─────────────────────────────────────────────────────────────
plotshape(newLow  and i_showBull, title="Bull Origin", style=shape.circle,
          location=location.belowbar, color=C_BUY_LBL,  size=size.tiny)
plotshape(newHigh and i_showBear, title="Bear Origin", style=shape.circle,
          location=location.abovebar, color=C_SELL_LBL, size=size.tiny)

// ─────────────────────────────────────────────────────────────
//  ALERTS
// ─────────────────────────────────────────────────────────────
// (Alerts are triggered by signal conditions above; use
//  TradingView's "Create Alert" on this indicator to capture them.)
