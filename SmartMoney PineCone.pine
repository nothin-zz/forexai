// ============================================================
// SMART MONEY PINE CONE — by Claude (SMC Indicator)
// TradingView Pine Script v5
// Includes: OB, BOS, CHoCH, FVG, Liquidity, Entry/SL/TP
// ============================================================
//@version=5
indicator("Smart Money Pine Cone 🌲", overlay=true, max_boxes_count=200, max_lines_count=300, max_labels_count=200)

// ─────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────
grp1 = "📦 Order Blocks"
ob_lookback    = input.int(10,   "OB Lookback Bars",        minval=3,  maxval=50,  group=grp1)
ob_count       = input.int(3,    "Show Last N OBs",         minval=1,  maxval=10,  group=grp1)
ob_bull_col    = input.color(color.new(#00e5ff, 80), "Bullish OB Color",  group=grp1)
ob_bear_col    = input.color(color.new(#ff1744, 80), "Bearish OB Color",  group=grp1)

grp2 = "📐 Structure (BOS / CHoCH)"
show_bos       = input.bool(true,  "Show BOS",   group=grp2)
show_choch     = input.bool(true,  "Show CHoCH", group=grp2)
struct_lookback = input.int(20,  "Structure Lookback", minval=5, maxval=100, group=grp2)

grp3 = "🕳️ Fair Value Gaps"
show_fvg       = input.bool(true,  "Show FVG",         group=grp3)
fvg_min_size   = input.float(0.1,  "FVG Min Size (%)", minval=0.01, maxval=5.0, group=grp3)
fvg_bull_col   = input.color(color.new(#00e676, 75), "Bullish FVG Color", group=grp3)
fvg_bear_col   = input.color(color.new(#ff5252, 75), "Bearish FVG Color", group=grp3)

grp4 = "💧 Liquidity"
show_liq       = input.bool(true, "Show Liquidity Levels", group=grp4)
liq_lookback   = input.int(15,   "Liquidity Lookback",    minval=5, maxval=50, group=grp4)
liq_tolerance  = input.float(0.2, "Equal H/L Tolerance (%)", minval=0.01, maxval=1.0, group=grp4)

grp5 = "🎯 Entry / SL / TP"
show_signals   = input.bool(true,  "Show Entry Signals",   group=grp5)
rr1            = input.float(1.0,  "TP1 RR Ratio", minval=0.5, maxval=5.0, group=grp5)
rr2            = input.float(2.0,  "TP2 RR Ratio", minval=0.5, maxval=10.0, group=grp5)
rr3            = input.float(3.0,  "TP3 RR Ratio", minval=0.5, maxval=15.0, group=grp5)
sl_buffer      = input.float(0.1,  "SL Buffer (%)", minval=0.0, maxval=1.0, group=grp5)

// ─────────────────────────────────────────
// UTILITY FUNCTIONS
// ─────────────────────────────────────────
pct(a, b) => math.abs(a - b) / b * 100

// ─────────────────────────────────────────
// 1. FAIR VALUE GAPS (FVG)
// ─────────────────────────────────────────
// Bullish FVG: low[0] > high[2]
// Bearish FVG: high[0] < low[2]
var box[] bull_fvg_boxes = array.new<box>()
var box[] bear_fvg_boxes = array.new<box>()

bull_fvg = low > high[2] and (low - high[2]) / high[2] * 100 >= fvg_min_size
bear_fvg = high < low[2] and (low[2] - high) / low[2] * 100 >= fvg_min_size

if show_fvg and bull_fvg
    b = box.new(bar_index - 2, low, bar_index + 30, high[2], border_color=na, bgcolor=fvg_bull_col)
    array.push(bull_fvg_boxes, b)

if show_fvg and bear_fvg
    b = box.new(bar_index - 2, high, bar_index + 30, low[2], border_color=na, bgcolor=fvg_bear_col)
    array.push(bear_fvg_boxes, b)

// Extend FVG boxes to current bar
if show_fvg
    for b in bull_fvg_boxes
        if box.get_right(b) >= bar_index - 1
            box.set_right(b, bar_index + 10)
            // Mitigate if price entered
            if close < box.get_top(b) and close > box.get_bottom(b)
                box.set_right(b, bar_index)
    for b in bear_fvg_boxes
        if box.get_right(b) >= bar_index - 1
            box.set_right(b, bar_index + 10)
            if close > box.get_bottom(b) and close < box.get_top(b)
                box.set_right(b, bar_index)

// ─────────────────────────────────────────
// 2. ORDER BLOCKS (OB)
// ─────────────────────────────────────────
// Bullish OB: last bearish candle before a strong bullish move
// Bearish OB: last bullish candle before a strong bearish move
var box[] bull_ob_boxes = array.new<box>()
var box[] bear_ob_boxes = array.new<box>()

// Detect bullish impulse (3 consecutive up closes)
bull_impulse = close > close[1] and close[1] > close[2] and close > open[ob_lookback]
bear_impulse = close < close[1] and close[1] < close[2] and close < open[ob_lookback]

// Find the last bearish candle in lookback for bull OB
bull_ob_found = false
bull_ob_hi    = 0.0
bull_ob_lo    = 0.0
bull_ob_bar   = 0

if bull_impulse
    for i = 1 to ob_lookback
        if close[i] < open[i] and not bull_ob_found
            bull_ob_found := true
            bull_ob_hi    := high[i]
            bull_ob_lo    := low[i]
            bull_ob_bar   := bar_index - i

bear_ob_found = false
bear_ob_hi    = 0.0
bear_ob_lo    = 0.0
bear_ob_bar   = 0

if bear_impulse
    for i = 1 to ob_lookback
        if close[i] > open[i] and not bear_ob_found
            bear_ob_found := true
            bear_ob_hi    := high[i]
            bear_ob_lo    := low[i]
            bear_ob_bar   := bar_index - i

if bull_ob_found
    b = box.new(bull_ob_bar, bull_ob_hi, bar_index + 20, bull_ob_lo,
         border_color=color.new(#00e5ff, 40), border_width=1, bgcolor=ob_bull_col)
    array.push(bull_ob_boxes, b)
    if array.size(bull_ob_boxes) > ob_count
        box.delete(array.shift(bull_ob_boxes))

if bear_ob_found
    b = box.new(bear_ob_bar, bear_ob_hi, bar_index + 20, bear_ob_lo,
         border_color=color.new(#ff1744, 40), border_width=1, bgcolor=ob_bear_col)
    array.push(bear_ob_boxes, b)
    if array.size(bear_ob_boxes) > ob_count
        box.delete(array.shift(bear_ob_boxes))

// Extend OB boxes
for b in bull_ob_boxes
    box.set_right(b, bar_index + 20)
for b in bear_ob_boxes
    box.set_right(b, bar_index + 20)

// ─────────────────────────────────────────
// 3. STRUCTURE — BOS & CHoCH
// ─────────────────────────────────────────
swing_high = ta.pivothigh(high, struct_lookback, struct_lookback)
swing_low  = ta.pivotlow(low,  struct_lookback, struct_lookback)

var float last_sh = na
var float last_sl = na
var int   last_sh_bar = na
var int   last_sl_bar = na

if not na(swing_high)
    last_sh     := swing_high
    last_sh_bar := bar_index - struct_lookback

if not na(swing_low)
    last_sl     := swing_low
    last_sl_bar := bar_index - struct_lookback

// BOS Bullish: close breaks above last swing high
bos_bull = not na(last_sh) and close > last_sh and close[1] <= last_sh
// BOS Bearish: close breaks below last swing low
bos_bear = not na(last_sl) and close < last_sl and close[1] >= last_sl

// CHoCH: trend reversal (simplified — price breaks opposite structure)
choch_bull = bos_bull and close[1] < last_sl  // was bearish, now breaks up
choch_bear = bos_bear and close[1] > last_sh  // was bullish, now breaks down

if show_bos and bos_bull and not choch_bull
    line.new(last_sh_bar, last_sh, bar_index, last_sh,
         color=#00e676, width=1, style=line.style_dashed)
    label.new(bar_index, last_sh, "BOS", color=color.new(#00e676, 20),
         textcolor=color.white, size=size.tiny, style=label.style_label_down)

if show_bos and bos_bear and not choch_bear
    line.new(last_sl_bar, last_sl, bar_index, last_sl,
         color=#ff5252, width=1, style=line.style_dashed)
    label.new(bar_index, last_sl, "BOS", color=color.new(#ff5252, 20),
         textcolor=color.white, size=size.tiny, style=label.style_label_up)

if show_choch and choch_bull
    line.new(last_sh_bar, last_sh, bar_index, last_sh,
         color=#ffea00, width=2, style=line.style_dotted)
    label.new(bar_index, last_sh, "CHoCH", color=color.new(#ffea00, 20),
         textcolor=color.black, size=size.tiny, style=label.style_label_down)

if show_choch and choch_bear
    line.new(last_sl_bar, last_sl, bar_index, last_sl,
         color=#ff9100, width=2, style=line.style_dotted)
    label.new(bar_index, last_sl, "CHoCH", color=color.new(#ff9100, 20),
         textcolor=color.black, size=size.tiny, style=label.style_label_up)

// ─────────────────────────────────────────
// 4. LIQUIDITY LEVELS (Equal Highs / Lows)
// ─────────────────────────────────────────
var line[] liq_lines = array.new<line>()

if show_liq
    for i = 1 to liq_lookback
        for j = i + 1 to liq_lookback
            // Equal Highs (Buy-side Liquidity)
            if pct(high[i], high[j]) <= liq_tolerance
                avg_h = (high[i] + high[j]) / 2
                if high[0] > avg_h and high[1] <= avg_h  // swept
                    label.new(bar_index, avg_h, "BSL 💧", color=color.new(#00bcd4, 30),
                         textcolor=color.white, size=size.tiny, style=label.style_label_down)
            // Equal Lows (Sell-side Liquidity)
            if pct(low[i], low[j]) <= liq_tolerance
                avg_l = (low[i] + low[j]) / 2
                if low[0] < avg_l and low[1] >= avg_l  // swept
                    label.new(bar_index, avg_l, "SSL 💧", color=color.new(#e91e63, 30),
                         textcolor=color.white, size=size.tiny, style=label.style_label_up)

// ─────────────────────────────────────────
// 5. SMART ENTRY SIGNAL (OB + BOS Confluence)
// ─────────────────────────────────────────
// LONG: price retests a bullish OB after BOS bullish
// SHORT: price retests a bearish OB after BOS bearish

var bool in_bull_ob = false
var bool in_bear_ob = false
var float ob_hi_ref = na
var float ob_lo_ref = na

// Check if current price is inside any bullish OB
if array.size(bull_ob_boxes) > 0
    last_bull_ob = array.get(bull_ob_boxes, array.size(bull_ob_boxes) - 1)
    ob_top = box.get_top(last_bull_ob)
    ob_bot = box.get_bottom(last_bull_ob)
    in_bull_ob := low <= ob_top and low >= ob_bot
    ob_hi_ref  := ob_top
    ob_lo_ref  := ob_bot

if array.size(bear_ob_boxes) > 0
    last_bear_ob = array.get(bear_ob_boxes, array.size(bear_ob_boxes) - 1)
    ob_top2 = box.get_top(last_bear_ob)
    ob_bot2 = box.get_bottom(last_bear_ob)
    in_bear_ob := high >= ob_bot2 and high <= ob_top2
    ob_hi_ref  := ob_top2
    ob_lo_ref  := ob_bot2

// LONG SIGNAL: BOS bull + price in bullish OB + bullish candle
long_signal  = show_signals and bos_bull and in_bull_ob and close > open
// SHORT SIGNAL: BOS bear + price in bearish OB + bearish candle
short_signal = show_signals and bos_bear and in_bear_ob and close < open

// ─────────────────────────────────────────
// 6. ENTRY / SL / TP LEVELS
// ─────────────────────────────────────────
if long_signal
    entry = close
    sl    = ob_lo_ref * (1 - sl_buffer / 100)
    risk  = entry - sl
    tp1   = entry + risk * rr1
    tp2   = entry + risk * rr2
    tp3   = entry + risk * rr3

    // Entry arrow
    label.new(bar_index, low, "▲ LONG\n" +
         "Entry: " + str.tostring(entry, "#.####") + "\n" +
         "SL: "    + str.tostring(sl,    "#.####") + "\n" +
         "TP1: "   + str.tostring(tp1,   "#.####") + "\n" +
         "TP2: "   + str.tostring(tp2,   "#.####") + "\n" +
         "TP3: "   + str.tostring(tp3,   "#.####"),
         color=#00e676, textcolor=color.black,
         style=label.style_label_up, size=size.normal)

    // SL line
    line.new(bar_index, sl,  bar_index + 15, sl,  color=#ff1744, width=1, style=line.style_solid)
    // TP lines
    line.new(bar_index, tp1, bar_index + 15, tp1, color=#69f0ae, width=1, style=line.style_dashed)
    line.new(bar_index, tp2, bar_index + 15, tp2, color=#00e676, width=1, style=line.style_dashed)
    line.new(bar_index, tp3, bar_index + 15, tp3, color=#1b5e20, width=2, style=line.style_solid)

    // TP labels
    label.new(bar_index + 15, tp1, "TP1 (" + str.tostring(rr1) + "R)", color=#69f0ae, textcolor=color.black, size=size.tiny, style=label.style_label_left)
    label.new(bar_index + 15, tp2, "TP2 (" + str.tostring(rr2) + "R)", color=#00e676, textcolor=color.black, size=size.tiny, style=label.style_label_left)
    label.new(bar_index + 15, tp3, "TP3 (" + str.tostring(rr3) + "R)", color=#1b5e20, textcolor=color.white, size=size.tiny, style=label.style_label_left)
    label.new(bar_index + 15, sl,  "SL",                                color=#ff1744, textcolor=color.white, size=size.tiny, style=label.style_label_left)

if short_signal
    entry = close
    sl    = ob_hi_ref * (1 + sl_buffer / 100)
    risk  = sl - entry
    tp1   = entry - risk * rr1
    tp2   = entry - risk * rr2
    tp3   = entry - risk * rr3

    label.new(bar_index, high, "▼ SHORT\n" +
         "Entry: " + str.tostring(entry, "#.####") + "\n" +
         "SL: "    + str.tostring(sl,    "#.####") + "\n" +
         "TP1: "   + str.tostring(tp1,   "#.####") + "\n" +
         "TP2: "   + str.tostring(tp2,   "#.####") + "\n" +
         "TP3: "   + str.tostring(tp3,   "#.####"),
         color=#ff5252, textcolor=color.white,
         style=label.style_label_down, size=size.normal)

    line.new(bar_index, sl,  bar_index + 15, sl,  color=#ff1744, width=1, style=line.style_solid)
    line.new(bar_index, tp1, bar_index + 15, tp1, color=#ff8a80, width=1, style=line.style_dashed)
    line.new(bar_index, tp2, bar_index + 15, tp2, color=#ff5252, width=1, style=line.style_dashed)
    line.new(bar_index, tp3, bar_index + 15, tp3, color=#b71c1c, width=2, style=line.style_solid)

    label.new(bar_index + 15, tp1, "TP1 (" + str.tostring(rr1) + "R)", color=#ff8a80, textcolor=color.black, size=size.tiny, style=label.style_label_left)
    label.new(bar_index + 15, tp2, "TP2 (" + str.tostring(rr2) + "R)", color=#ff5252, textcolor=color.white, size=size.tiny, style=label.style_label_left)
    label.new(bar_index + 15, tp3, "TP3 (" + str.tostring(rr3) + "R)", color=#b71c1c, textcolor=color.white, size=size.tiny, style=label.style_label_left)
    label.new(bar_index + 15, sl,  "SL",                                color=#ff1744, textcolor=color.white, size=size.tiny, style=label.style_label_left)

// ─────────────────────────────────────────
// 7. ALERT CONDITIONS
// ─────────────────────────────────────────
alertcondition(long_signal,  "🟢 SMC LONG Signal",  "Smart Money Pine Cone — LONG signal on " + syminfo.ticker)
alertcondition(short_signal, "🔴 SMC SHORT Signal", "Smart Money Pine Cone — SHORT signal on " + syminfo.ticker)
alertcondition(bos_bull,     "BOS Bullish",          "Break of Structure UP — " + syminfo.ticker)
alertcondition(bos_bear,     "BOS Bearish",          "Break of Structure DOWN — " + syminfo.ticker)
alertcondition(choch_bull,   "CHoCH Bullish",        "Change of Character UP — " + syminfo.ticker)
alertcondition(choch_bear,   "CHoCH Bearish",        "Change of Character DOWN — " + syminfo.ticker)

// ─────────────────────────────────────────
// 8. DASHBOARD (top-right info table)
// ─────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 6,
     border_color=color.new(color.gray, 60), border_width=1,
     bgcolor=color.new(#0d0d0d, 20))

if barstate.islast
    table.cell(dash, 0, 0, "🌲 Smart Money Pine Cone", text_color=color.white,  bgcolor=color.new(#1a1a2e, 10), text_size=size.small)
    table.cell(dash, 1, 0, syminfo.ticker + " | " + timeframe.period, text_color=#00e5ff, bgcolor=color.new(#1a1a2e, 10), text_size=size.small)
    table.cell(dash, 0, 1, "OBs Active", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 1, str.tostring(array.size(bull_ob_boxes)) + "🟢 / " + str.tostring(array.size(bear_ob_boxes)) + "🔴", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 0, 2, "Last Signal", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 2, long_signal ? "▲ LONG 🟢" : short_signal ? "▼ SHORT 🔴" : "—", text_color=long_signal ? #00e676 : short_signal ? #ff5252 : color.gray, text_size=size.tiny)
    table.cell(dash, 0, 3, "TP Ratios", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 3, str.tostring(rr1) + "R / " + str.tostring(rr2) + "R / " + str.tostring(rr3) + "R", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 0, 4, "BOS Bull / Bear", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 4, (bos_bull ? "✅" : "—") + " / " + (bos_bear ? "✅" : "—"), text_color=color.white, text_size=size.tiny)
    table.cell(dash, 0, 5, "FVG / OB Sens", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 5, str.tostring(fvg_min_size) + "% / " + str.tostring(ob_lookback), text_color=color.white, text_size=size.tiny)
