//@version=5
indicator("Auto KEY Levels [ICT/SMC]", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=200)

// ═══════════════════════════════════════════════════════
//  SOZLAMALAR
// ═══════════════════════════════════════════════════════
grp1 = "🔑 KEY Level Sozlamalari"
lookback       = input.int(20,    "Swing Lookback",         minval=5,  maxval=100, group=grp1)
minTouches     = input.int(2,     "Minimum Touch soni",     minval=1,  maxval=10,  group=grp1)
zonePips       = input.float(10,  "Zone kengligi (pips)",   minval=1,  maxval=50,  group=grp1)
showLabels     = input.bool(true, "Label ko'rsatish",                             group=grp1)
showZones      = input.bool(true, "Zone (box) ko'rsatish",                        group=grp1)
extendLines    = input.bool(true, "Liniyani o'ngga uzaytirish",                   group=grp1)

grp2 = "🎨 Rang Sozlamalari"
colorSupport   = input.color(color.new(#00E5FF, 0),   "Support KEY rangi",  group=grp2)
colorResist    = input.color(color.new(#FF4444, 0),   "Resistance KEY rangi", group=grp2)
colorZoneSup   = input.color(color.new(#00E5FF, 85),  "Support Zone rangi", group=grp2)
colorZoneRes   = input.color(color.new(#FF4444, 85),  "Resistance Zone rangi", group=grp2)
lineWidth      = input.int(2, "Chiziq qalinligi", minval=1, maxval=4, group=grp2)

grp3 = "📊 Filtr Sozlamalari"
useHTF         = input.bool(true,  "HTF filter ishlatish",           group=grp3)
htfTF          = input.timeframe("D", "HTF Timeframe",               group=grp3)
minStrength    = input.int(3,  "Minimum Strength skori",  minval=1, maxval=10, group=grp3)

// ═══════════════════════════════════════════════════════
//  PIP HISOBLASH (valyuta juftligi uchun avtomatik)
// ═══════════════════════════════════════════════════════
pipSize = syminfo.mintick * (str.contains(syminfo.ticker, "JPY") ? 100 : 
          str.contains(syminfo.ticker, "XAU") ? 10 : 
          str.contains(syminfo.ticker, "XAG") ? 100 :
          str.contains(syminfo.ticker, "BTC") ? 1 :
          str.contains(syminfo.ticker, "ETH") ? 1 : 10)

zoneSize = zonePips * pipSize

// ═══════════════════════════════════════════════════════
//  SWING HIGH / LOW ANIQLASH
// ═══════════════════════════════════════════════════════
swingHigh = ta.pivothigh(high, lookback, lookback)
swingLow  = ta.pivotlow(low,  lookback, lookback)

// ═══════════════════════════════════════════════════════
//  TOUCH SONI VA KUCH HISOBLASH
// ═══════════════════════════════════════════════════════
f_countTouches(lvl, isHigh) =>
    touches = 0
    for i = 0 to 100
        price = isHigh ? high[i] : low[i]
        if math.abs(price - lvl) <= zoneSize
            touches += 1
    touches

f_levelStrength(lvl, isHigh) =>
    touches    = f_countTouches(lvl, isHigh)
    // Volume yaqinida kuchli bo'lsa +1
    volBonus   = volume > ta.sma(volume, 20) ? 1 : 0
    // HTF dan kelgan bo'lsa +2
    htfBonus   = useHTF ? 2 : 0
    touches + volBonus + htfBonus

// ═══════════════════════════════════════════════════════
//  KEY LEVEL CHIZISH
// ═══════════════════════════════════════════════════════
var line[]  keyLines  = array.new_line()
var box[]   keyBoxes  = array.new_box()
var label[] keyLabels = array.new_label()

// Eski elementlarni o'chirish (oxirgi 50 tasi saqlanadi)
f_cleanup() =>
    if array.size(keyLines) > 50
        line.delete(array.shift(keyLines))
    if array.size(keyBoxes) > 50
        box.delete(array.shift(keyBoxes))
    if array.size(keyLabels) > 50
        label.delete(array.shift(keyLabels))

f_drawKey(lvl, isHigh, barIdx) =>
    strength = f_levelStrength(lvl, isHigh)
    if strength >= minStrength
        col      = isHigh ? colorResist : colorSupport
        colZone  = isHigh ? colorZoneRes : colorZoneSup
        lStyle   = strength >= 6 ? line.style_solid : line.style_dashed
        extRight = extendLines ? extend.right : extend.none
        
        // Chiziq
        ln = line.new(barIdx, lvl, bar_index, lvl,
                      color=col, width=lineWidth,
                      style=lStyle, extend=extRight)
        array.push(keyLines, ln)
        
        // Zone (box)
        if showZones
            top    = isHigh ? lvl + zoneSize : lvl
            bottom = isHigh ? lvl : lvl - zoneSize
            bx = box.new(barIdx, top, bar_index, bottom,
                         border_color=col, border_width=1,
                         bgcolor=colZone, extend=extRight)
            array.push(keyBoxes, bx)
        
        // Label
        if showLabels
            touchCount = f_countTouches(lvl, isHigh)
            strengthTxt = strength >= 7 ? "🔴 MAJOR" : strength >= 5 ? "🟡 KEY" : "🟢 MINOR"
            labelTxt = strengthTxt + " KEY\n" +
                       str.tostring(lvl, format.mintick) + "\n" +
                       "Touch: " + str.tostring(touchCount)
            labelY   = isHigh ? lvl + zoneSize * 1.5 : lvl - zoneSize * 1.5
            lbAlign  = isHigh ? label.style_label_down : label.style_label_up
            lb = label.new(barIdx, labelY, labelTxt,
                           color=col, textcolor=color.white,
                           style=lbAlign, size=size.small)
            array.push(keyLabels, lb)

// ═══════════════════════════════════════════════════════
//  ASOSIY LOGIKA
// ═══════════════════════════════════════════════════════
if not na(swingHigh)
    f_cleanup()
    f_drawKey(swingHigh, true, bar_index[lookback])

if not na(swingLow)
    f_cleanup()
    f_drawKey(swingLow, false, bar_index[lookback])

// ═══════════════════════════════════════════════════════
//  JORIY NARX KEY LEVEL YAQINLIGI — ALERT
// ═══════════════════════════════════════════════════════
var float nearestSup = na
var float nearestRes = na

if not na(swingLow)
    nearestSup := swingLow
if not na(swingHigh)
    nearestRes := swingHigh

nearSupport    = not na(nearestSup) and math.abs(close - nearestSup) <= zoneSize * 3
nearResistance = not na(nearestRes) and math.abs(close - nearestRes) <= zoneSize * 3

// Alert shartlari
alertcondition(nearSupport,    "KEY Support yaqin",    "Narx KEY Support zonasiga yaqinlashdi!")
alertcondition(nearResistance, "KEY Resistance yaqin", "Narx KEY Resistance zonasiga yaqinlashdi!")
alertcondition(ta.crossover(close, nearestRes),  "KEY Resistance buzildi (Breakout)", "KEY Resistance breakout!")
alertcondition(ta.crossunder(close, nearestSup), "KEY Support buzildi (Breakdown)",   "KEY Support breakdown!")

// ═══════════════════════════════════════════════════════
//  DASHBOARD — JORIY HOLAT
// ═══════════════════════════════════════════════════════
var table dash = table.new(position.top_right, 2, 6,
                           bgcolor=color.new(color.black, 20),
                           border_color=color.new(color.gray, 50),
                           border_width=1)

if barstate.islast
    table.cell(dash, 0, 0, "🔑 KEY LEVELS",  text_color=color.white,  text_size=size.normal, bgcolor=color.new(color.navy, 30))
    table.cell(dash, 1, 0, syminfo.ticker,    text_color=color.yellow, text_size=size.normal, bgcolor=color.new(color.navy, 30))
    
    table.cell(dash, 0, 1, "Timeframe",  text_color=color.gray,  text_size=size.small)
    table.cell(dash, 1, 1, timeframe.period + "m", text_color=color.white, text_size=size.small)
    
    table.cell(dash, 0, 2, "Resistance", text_color=colorResist, text_size=size.small)
    table.cell(dash, 1, 2, na(nearestRes) ? "—" : str.tostring(nearestRes, format.mintick),
               text_color=colorResist, text_size=size.small)
    
    table.cell(dash, 0, 3, "Support",    text_color=colorSupport, text_size=size.small)
    table.cell(dash, 1, 3, na(nearestSup) ? "—" : str.tostring(nearestSup, format.mintick),
               text_color=colorSupport, text_size=size.small)
    
    supDist = na(nearestSup) ? na : math.abs(close - nearestSup) / pipSize
    resDist = na(nearestRes) ? na : math.abs(close - nearestRes) / pipSize
    
    table.cell(dash, 0, 4, "Sup Masofa", text_color=color.gray,   text_size=size.small)
    table.cell(dash, 1, 4, na(supDist) ? "—" : str.tostring(math.round(supDist, 1)) + " pip",
               text_color=color.white, text_size=size.small)
    
    table.cell(dash, 0, 5, "Res Masofa", text_color=color.gray,   text_size=size.small)
    table.cell(dash, 1, 5, na(resDist) ? "—" : str.tostring(math.round(resDist, 1)) + " pip",
               text_color=color.white, text_size=size.small)
